# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Notification polling for mechanics
# 1 = only alert on nearby unassigned requests, 0 = all unassigned requests
NOTIFICATION_NEARBY_ONLY=0
# Nearby radius in kilometers when NOTIFICATION_NEARBY_ONLY=1
NOTIFICATION_RADIUS_KM=25
